{
  "entityName": "product-image",
  "apiEndpoint": "product-images",
  "tableId": "product-images-table",
  "tabName": "product-images",
  "formId": "product-image-form",
  "formContainerId": "productImageForm",
  "onLoadComplete": "onProductsLoaded",
  "crudId": "productImages",

  "primaryKeyConfig": {
    "type": "composite",
    "fields": ["product.id", "imageUrl"]
  },

  "defaultSearchField": "imageUrl",
  "enableSearch": true,
  "columns": [
    {
      "key": "product.id",
      "label": "Product id",
      "display": true,
      "searchable": false
    },
    {
      "key": "product.name",
      "label": "Product name",
      "display": true,
      "searchable": true
    },
    {
      "key": "product.category.name",
      "label": "Category",
      "display": true,
      "searchable": true
    },
    {
      "key": "imageUrl",
      "label": "Image Url",
      "display": true,
      "searchable": true 
    }
  ],
  "formFields": [
    {
      "id": "product-image-product",
      "key": "product",
      "label": "Product",
      "type": "select",
      "relationshipKey": "product",
      "required": true
    },
    {
      "id": "product-image-image-url",
      "key": "imageUrl",
      "label": "Image Url",
      "type": "url",
      "required": true,
      "placeholder": "https://example.com/image.jpg",
      "pattern": "https?://.+",
      "maxLength": 500
    }
  ]
}
