{
  "entityName": "address",
  "apiEndpoint": "addresses",
  "tableId": "addresses-table",
  "tabName": "addresses",
  "formId": "address-form",
  "formContainerId": "addressForm",
  "crudId": "addresses",

  "defaultSearchField": "street",
  "enableSearch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "display": true,
      "searchable": false 
    },
    {
      "key": "street",
      "label": "Street",
      "display": true,
      "searchable": true 
    },
    {
      "key": "city",
      "label": "City",
      "display": true,
      "searchable": true 
    },
    {
      "key": "zipCode",
      "label": "Zip Code",
      "display": true,
      "searchable": true 
    }
  ],
  "formFields": [
    {
      "id": "address-street",
      "key": "street",
      "label": "Street",
      "type": "text",
      "required": true,
      "placeholder": "Enter street address",
      "pattern": "[a-zA-Z0-9\\s,.\\-]*",
      "maxLength": 100
    },
    {
      "id": "address-city",
      "key": "city",
      "label": "City",
      "type": "text",
      "required": true,
      "placeholder": "Enter city name",
      "pattern": "[a-zA-Z\\s]*",
      "maxLength": 50
    },
    {
      "id": "address-zipCode",
      "key": "zipCode",
      "label": "Zip Code",
      "type": "text",
      "required": true,
      "placeholder": "Enter zip code",
      "pattern": "[0-9\\-]*",
      "maxLength": 10
    }
  ]
}

